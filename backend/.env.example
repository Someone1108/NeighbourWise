DATABASE_URL=
MAPBOX_TOKEN=

# EPA Victoria Environment Monitoring API / AirWatch
# Get this from https://portal.api.epa.vic.gov.au/ after subscribing to the API product.
EPA_AIRWATCH_API_KEY=

# Defaults target the Environment Monitoring v1 API. Override these if the
# developer portal shows a different gateway/path after login.
EPA_AIRWATCH_API_BASE_URL=https://gateway.api.epa.vic.gov.au/environmentMonitoring/v1
EPA_AIRWATCH_SITES_PATH=/sites?environmentalSegment=air
EPA_AIRWATCH_SITE_PARAMETERS_PATH=/sites/{siteId}/parameters
